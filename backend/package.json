{
  "name": "campus-event-management",
  "version": "1.0.0",
  "description": "Campus Event Management and Ticketing System - A centralized platform for managing campus events, registrations, and ticketing using QR codes.",
  "main": "./src/server.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "build": "npm run lint && npm run test",
    "predeploy": "npm run build && npm run db:migrate",
    "docs": "jsdoc src -d docs/api"
  },
  "keywords": [
    "events",
    "campus",
    "ticketing",
    "qr-code",
    "management",
    "registration"
  ],
  "author": "Campus Events Team",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "prisma": "^6.19.3",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jsdoc": "^4.0.0",
    "nodemon": "^3.0.0",
    "supertest": "^6.3.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/campus-event-management.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/campus-event-management/issues"
  },
  "homepage": "https://github.com/your-org/campus-event-management#readme"
}
